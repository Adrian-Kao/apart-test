rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function room(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId)).data;
    }

    function isMember(roomId) {
      let data = room(roomId);
      return signedIn()
        && (
          (data.members.userA != null && data.members.userA.userId == request.auth.uid)
          || (data.members.userB != null && data.members.userB.userId == request.auth.uid)
        );
    }

    function canPreviewForJoin(roomId) {
      let data = room(roomId);
      return signedIn() && (data.members.userA == null || data.members.userB == null);
    }

    function isJoiningUserA() {
      return signedIn()
        && resource.data.members.userA == null
        && request.resource.data.members.userA != null
        && request.resource.data.members.userA.userId == request.auth.uid
        && request.resource.data.members.userA.avatarType == "lion";
    }

    function isJoiningUserB() {
      return signedIn()
        && resource.data.members.userB == null
        && request.resource.data.members.userB != null
        && request.resource.data.members.userB.userId == request.auth.uid
        && request.resource.data.members.userB.avatarType == "lion";
    }

    function isJoiningRoom() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(["members", "updatedAt"])
        && (
          isJoiningUserA()
          || isJoiningUserB()
        );
    }

    match /rooms/{roomId} {
      allow create: if signedIn();
      allow read: if isMember(roomId) || canPreviewForJoin(roomId);
      allow update: if isMember(roomId) || isJoiningRoom();

      match /messages/{messageId} {
        allow read, create: if isMember(roomId);
      }

      match /dailyUsage/{usageId} {
        allow read: if isMember(roomId);
        allow create, update: if isMember(roomId)
          && request.resource.data.userId == request.auth.uid;
      }
    }
  }
}
